# ── Required ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Twitter/X API (free) ────────────────────────────────────────────────────────
# Get free Bearer Token in 2 min:
#   1. developer.twitter.com → sign up (free)
#   2. Create a project + app
#   3. Keys & Tokens → Bearer Token → copy
# Without this: uses city-specific mock tweets (app still works)
TWITTER_BEARER_TOKEN=

# ── Reddit API (free) ───────────────────────────────────────────────────────────
# Get free credentials in 2 min:
#   1. reddit.com/prefs/apps → "create another app"
#   2. Type: script | Name: CivicPulse | redirect: http://localhost
#   3. client_id = string under app name | client_secret = "secret" field
# Without this: Reddit source is skipped (Twitter + News RSS still runs)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Email dispatch (optional) ───────────────────────────────────────────────────
# Gmail app password: myaccount.google.com → Security → 2FA → App Passwords
# Without this: email is simulated (logged, not sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
